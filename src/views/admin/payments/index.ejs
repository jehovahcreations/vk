<% const pageTitle = "Payments"; %>
<%- include('../../partials/auth-head') %>

<div class="min-h-screen bg-slate-50 flex">
  <input id="admin-drawer" type="checkbox" class="peer hidden" />
  <%- include('../../partials/sidebar-admin') %>
  <label for="admin-drawer" class="fixed inset-0 bg-black/30 backdrop-blur-sm opacity-0 pointer-events-none peer-checked:opacity-100 peer-checked:pointer-events-auto transition lg:hidden"></label>

  <div class="flex-1 flex flex-col min-h-screen">
    <header class="sticky top-0 z-30 bg-white/90 backdrop-blur border-b border-slate-200">
      <div class="px-6 py-5 flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-500">Admin</p>
          <h1 class="text-2xl font-semibold">Payments</h1>
        </div>
      </div>
    </header>

    <main class="flex-1 px-6 py-8 space-y-6">
      <section class="card p-6">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold">Payment list</h2>
        </div>
        <div class="mt-6 overflow-x-auto">
          <table class="table-base min-w-[880px]">
            <thead>
              <tr>
                <th>Order ID</th>
                <th>Razorpay Order</th>
                <th>Payment ID</th>
                <th>Student</th>
                <th>Product</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Created</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (!payments.length) { %>
                <tr>
                  <td colspan="9" class="text-center text-sm text-slate-500 py-6">No payments yet.</td>
                </tr>
              <% } %>
              <% payments.forEach((payment) => { %>
                <tr>
                  <td><%= payment.purchase_order_id %></td>
                  <td><%= payment.razorpay_order_id || '-' %></td>
                  <td><%= payment.razorpay_payment_id || '-' %></td>
                  <td><%= payment.student_name %></td>
                  <td><%= payment.product_title %></td>
                  <td>INR <%= (payment.amount_in_paise / 100).toFixed(2) %></td>
                  <td>
                    <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold <%= payment.status === 'captured' ? 'bg-emerald-100 text-emerald-700' : payment.status === 'failed' ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700' %>">
                      <%= payment.status %>
                    </span>
                  </td>
                  <td><%= new Date(payment.created_at).toLocaleDateString() %></td>
                  <td><a class="btn-outline" href="/admin/payments/<%= payment.id %>">View</a></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>
</div>

</body>
</html>
