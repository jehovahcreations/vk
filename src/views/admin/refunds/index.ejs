<% const pageTitle = "Refunds"; %>
<%- include('../../partials/auth-head') %>

<div class="min-h-screen bg-slate-50 flex">
  <input id="admin-drawer" type="checkbox" class="peer hidden" />
  <%- include('../../partials/sidebar-admin') %>
  <label for="admin-drawer" class="fixed inset-0 bg-black/30 backdrop-blur-sm opacity-0 pointer-events-none peer-checked:opacity-100 peer-checked:pointer-events-auto transition lg:hidden"></label>

  <div class="flex-1 flex flex-col min-h-screen">
    <header class="sticky top-0 z-30 bg-white/90 backdrop-blur border-b border-slate-200">
      <div class="px-6 py-5 flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-500">Admin</p>
          <h1 class="text-2xl font-semibold">Refund requests</h1>
        </div>
      </div>
    </header>

    <main class="flex-1 px-6 py-8">
      <section class="card p-6">
        <div class="mt-6 overflow-x-auto">
          <table class="table-base min-w-[720px]">
            <thead>
              <tr>
                <th>Student</th>
                <th>Payment</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (!refunds.length) { %>
                <tr>
                  <td colspan="5" class="text-center text-sm text-slate-500 py-6">No refund requests yet.</td>
                </tr>
              <% } %>
              <% refunds.forEach((refund) => { %>
                <tr>
                  <td><%= refund.student_name || '-' %></td>
                  <td><%= refund.razorpay_payment_id || '-' %></td>
                  <td>INR <%= (refund.amount_in_paise / 100).toFixed(2) %></td>
                  <td><span class="badge"><%= refund.status %></span></td>
                  <td class="space-x-2">
                    <form class="inline" method="POST" action="/admin/refunds/<%= refund.id %>/approve">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <button class="btn-outline" type="submit">Approve</button>
                    </form>
                    <form class="inline" method="POST" action="/admin/refunds/<%= refund.id %>/reject">
                      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                      <button class="btn-outline" type="submit">Reject</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>
</div>

</body>
</html>
