<% const pageTitle = "Commissions"; %>
<%- include('../../partials/auth-head') %>

<div class="min-h-screen bg-slate-50 flex">
  <input id="admin-drawer" type="checkbox" class="peer hidden" />
  <%- include('../../partials/sidebar-admin') %>
  <label for="admin-drawer" class="fixed inset-0 bg-black/30 backdrop-blur-sm opacity-0 pointer-events-none peer-checked:opacity-100 peer-checked:pointer-events-auto transition lg:hidden"></label>

  <div class="flex-1 flex flex-col min-h-screen">
    <header class="sticky top-0 z-30 bg-white/90 backdrop-blur border-b border-slate-200">
      <div class="px-6 py-5 flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-500">Admin</p>
          <h1 class="text-2xl font-semibold">Commissions</h1>
        </div>
      </div>
    </header>

    <main class="flex-1 px-6 py-8 space-y-6">
      <% if (flashMessages && flashMessages.length) { %>
        <div class="space-y-2">
          <% flashMessages.forEach((item) => { %>
            <div class="card p-4">
              <p class="text-sm <%= item.type === 'error' ? 'text-red-600' : 'text-emerald-600' %>"><%= item.message %></p>
            </div>
          <% }) %>
        </div>
      <% } %>

      <section class="card p-6">
        <form class="grid gap-4 md:grid-cols-6" method="GET" action="/admin/commissions">
          <div class="md:col-span-2">
            <label class="text-sm font-medium">Search beneficiary</label>
            <input class="input mt-2" name="search" value="<%= filters?.search || '' %>" placeholder="Name or email" />
          </div>
          <div class="md:col-span-2">
            <label class="text-sm font-medium">Beneficiary</label>
            <select class="input mt-2" name="beneficiary_user_id">
              <option value="">All users</option>
              <% (beneficiaryBalances || []).forEach((row) => { %>
                <option value="<%= row.beneficiary_user_id %>" <%= (filters?.beneficiaryUserId || '') === row.beneficiary_user_id ? 'selected' : '' %>>
                  <%= row.beneficiary_name %> (<%= row.beneficiary_email %>)
                </option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="text-sm font-medium">Payout status</label>
            <select class="input mt-2" name="payout_status">
              <option value="active" <%= (filters?.payoutStatus || 'active') === 'active' ? 'selected' : '' %>>Active</option>
              <option value="voided" <%= (filters?.payoutStatus || '') === 'voided' ? 'selected' : '' %>>Deleted</option>
              <option value="all" <%= (filters?.payoutStatus || '') === 'all' ? 'selected' : '' %>>All</option>
            </select>
          </div>
          <div class="flex items-end gap-2">
            <button class="btn-primary w-full" type="submit">Apply</button>
          </div>
        </form>
      </section>

      <section class="grid gap-4 md:grid-cols-3">
        <div class="stat-card">
          <p class="text-xs text-slate-500">Total commissions</p>
          <p class="text-2xl font-semibold"><%= stats.totalCommissions %></p>
        </div>
        <div class="stat-card">
          <p class="text-xs text-slate-500">Total amount credited</p>
          <p class="text-2xl font-semibold">INR <%= (stats.totalCommissionAmountInPaise / 100).toFixed(2) %></p>
        </div>
        <div class="stat-card">
          <p class="text-xs text-slate-500">Unique earning users</p>
          <p class="text-2xl font-semibold"><%= stats.totalBeneficiaries %></p>
        </div>
      </section>

      <section class="grid gap-4 md:grid-cols-3">
        <div class="stat-card">
          <p class="text-xs text-slate-500">Outstanding balance</p>
          <p class="text-2xl font-semibold">INR <%= (stats.totalAvailableBalanceInPaise / 100).toFixed(2) %></p>
        </div>
        <div class="stat-card">
          <p class="text-xs text-slate-500">Total paid out</p>
          <p class="text-2xl font-semibold">INR <%= (stats.totalPaidOutInPaise / 100).toFixed(2) %></p>
        </div>
        <div class="stat-card">
          <p class="text-xs text-slate-500">Pending commissions</p>
          <p class="text-2xl font-semibold">INR <%= (stats.totalPendingInPaise / 100).toFixed(2) %></p>
        </div>
      </section>

      <section class="card p-6">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold">Record manual payout</h2>
        </div>
        <form class="grid gap-4 mt-6 md:grid-cols-4" method="POST" action="/admin/commissions/payouts">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="md:col-span-2">
            <label class="text-sm font-medium">Beneficiary user</label>
            <select class="input mt-2" name="beneficiary_user_id" required>
              <option value="">Select user</option>
              <% (beneficiaryBalances || []).forEach((row) => { %>
                <option value="<%= row.beneficiary_user_id %>">
                  <%= row.beneficiary_name %> (<%= row.beneficiary_email %>) - Available INR <%= (Number(row.available_balance_in_paise || 0) / 100).toFixed(2) %>
                </option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="text-sm font-medium">Amount (INR)</label>
            <input class="input mt-2" type="number" step="0.01" min="0.01" name="amount_in_inr" required />
          </div>
          <div>
            <label class="text-sm font-medium">Paid at</label>
            <input class="input mt-2" type="datetime-local" name="paid_at" />
          </div>
          <div class="md:col-span-3">
            <label class="text-sm font-medium">Notes</label>
            <input class="input mt-2" type="text" maxlength="240" name="notes" placeholder="UPI ref / bank transfer note" />
          </div>
          <div class="md:col-span-1 flex items-end">
            <button class="btn-primary w-full" type="submit">Save payout</button>
          </div>
        </form>
      </section>

      <section class="card p-6">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold">Beneficiary balances</h2>
        </div>
        <div class="mt-6 overflow-x-auto">
          <table class="table-base min-w-[980px]">
            <thead>
              <tr>
                <th>User</th>
                <th>Credited</th>
                <th>Paid out</th>
                <th>Available</th>
                <th>Pending</th>
              </tr>
            </thead>
            <tbody>
              <% if (!beneficiaryBalances.length) { %>
                <tr>
                  <td colspan="5" class="text-center text-sm text-slate-500 py-6">No beneficiary balances available.</td>
                </tr>
              <% } %>
              <% beneficiaryBalances.forEach((item) => { %>
                <tr>
                  <td>
                    <div class="font-medium"><%= item.beneficiary_name %></div>
                    <div class="text-xs text-slate-500"><%= item.beneficiary_email %></div>
                  </td>
                  <td>INR <%= (Number(item.credited_in_paise || 0) / 100).toFixed(2) %></td>
                  <td>INR <%= (Number(item.paid_out_in_paise || 0) / 100).toFixed(2) %></td>
                  <td class="font-medium">INR <%= (Number(item.available_balance_in_paise || 0) / 100).toFixed(2) %></td>
                  <td>INR <%= (Number(item.pending_in_paise || 0) / 100).toFixed(2) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section class="card p-6">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold">Recent payouts</h2>
          <a
            class="btn-outline"
            href="/admin/commissions/payouts/export?search=<%= encodeURIComponent(filters?.search || '') %>&payout_status=<%= encodeURIComponent(filters?.payoutStatus || 'all') %>&beneficiary_user_id=<%= encodeURIComponent(filters?.beneficiaryUserId || '') %>"
          >Export CSV</a>
        </div>
        <div class="mt-6 overflow-x-auto">
          <table class="table-base min-w-[1220px]">
            <thead>
              <tr>
                <th>Beneficiary</th>
                <th>Amount</th>
                <th>Paid at</th>
                <th>Status</th>
                <th>Recorded by</th>
                <th>Notes</th>
                <th class="text-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (!payouts.length) { %>
                <tr>
                  <td colspan="7" class="text-center text-sm text-slate-500 py-6">No payouts recorded yet.</td>
                </tr>
              <% } %>
              <% payouts.forEach((item) => { %>
                <tr>
                  <td>
                    <div class="font-medium"><%= item.beneficiary_name %></div>
                    <div class="text-xs text-slate-500"><%= item.beneficiary_email %></div>
                  </td>
                  <td>INR <%= (Number(item.amount_in_paise || 0) / 100).toFixed(2) %></td>
                  <td><%= new Date(item.paid_at || item.created_at).toLocaleString() %></td>
                  <td>
                    <span class="badge <%= item.is_voided ? 'badge-muted' : 'badge-success' %>">
                      <%= item.is_voided ? 'Deleted' : 'Active' %>
                    </span>
                  </td>
                  <td><%= item.created_by_name || 'Admin' %></td>
                  <td class="text-sm text-slate-500"><%= item.notes || '-' %></td>
                  <td>
                    <% if (!item.is_voided) { %>
                      <div class="flex items-center justify-end gap-2">
                        <form class="flex items-center gap-2" method="POST" action="/admin/commissions/payouts/<%= item.id %>/update">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <input class="input w-24" type="number" step="0.01" min="0.01" name="amount_in_inr" value="<%= (Number(item.amount_in_paise || 0) / 100).toFixed(2) %>" required />
                          <input class="input w-44" type="datetime-local" name="paid_at" value="<%= new Date(item.paid_at || item.created_at).toISOString().slice(0, 16) %>" required />
                          <input class="input w-48" type="text" name="notes" maxlength="240" value="<%= item.notes || '' %>" />
                          <button class="btn-outline" type="submit">Update</button>
                        </form>
                        <form method="POST" action="/admin/commissions/payouts/<%= item.id %>/delete" onsubmit="return confirm('Delete this payout record?');">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <button class="btn-outline" type="submit">Delete</button>
                        </form>
                      </div>
                    <% } else { %>
                      <span class="text-xs text-slate-500">No actions</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>

      <section class="card p-6">
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold">Commission ledger</h2>
        </div>
        <div class="mt-6 overflow-x-auto">
          <table class="table-base min-w-[1080px]">
            <thead>
              <tr>
                <th>Beneficiary</th>
                <th>Buyer</th>
                <th>Video</th>
                <th>Rate</th>
                <th>Commission</th>
                <th>Status</th>
                <th>Order</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% if (!commissions.length) { %>
                <tr>
                  <td colspan="8" class="text-center text-sm text-slate-500 py-6">No commissions generated yet.</td>
                </tr>
              <% } %>
              <% commissions.forEach((item) => { %>
                <tr>
                  <td>
                    <div class="font-medium"><%= item.beneficiary_name %></div>
                    <div class="text-xs text-slate-500"><%= item.beneficiary_email %></div>
                  </td>
                  <td>
                    <div class="font-medium"><%= item.buyer_name %></div>
                    <div class="text-xs text-slate-500"><%= item.buyer_email %></div>
                  </td>
                  <td><%= item.product_title || '-' %></td>
                  <td><%= Number(item.commission_percent || 0).toFixed(2) %>%</td>
                  <td>INR <%= (Number(item.commission_amount_in_paise || 0) / 100).toFixed(2) %></td>
                  <td><span class="badge"><%= item.status %></span></td>
                  <td class="text-xs text-slate-500"><%= item.purchase_order_id %></td>
                  <td><%= new Date(item.created_at).toLocaleDateString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>
</div>

</body>
</html>
