<% const pageTitle = "Register - VK Training Consultency"; %>
<%- include('../partials/auth-head') %>

<section class="relative overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute -top-20 -right-24 h-64 w-64 rounded-full" style="background: rgba(151, 216, 243, 0.35);"></div>
    <div class="absolute -bottom-24 -left-20 h-72 w-72 rounded-full" style="background: rgba(245, 139, 5, 0.2);"></div>
  </div>
  <div class="relative max-w-6xl mx-auto px-6 py-16 grid gap-10 lg:grid-cols-2">
    <%- include('../partials/auth-brand-panel') %>
    <div class="card p-10">
      <h2 class="text-3xl font-semibold">Create your account</h2>
      <p class="text-slate-500 mt-2">Join the premium pay-and-watch learning platform.</p>
      <%- include('../partials/auth-alert') %>
      <form class="mt-6 space-y-5" method="POST" action="/register">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <%- include('../partials/form-input', { label: 'Full name', name: 'full_name', value: formData.full_name, placeholder: 'Ava Thompson', required: true }) %>
        <%- include('../partials/form-input', { label: 'Email address', name: 'email', value: formData.email, placeholder: 'you@company.com', required: true }) %>
        <%- include('../partials/form-input', { label: 'Phone number', name: 'phone', value: formData.phone, placeholder: '+1 555 123 4567', required: true }) %>
        <%- include('../partials/form-input', { label: 'Password', name: 'password', type: 'password', placeholder: 'Create a password', required: true }) %>
        <%- include('../partials/form-input', { label: 'Confirm password', name: 'confirm_password', type: 'password', placeholder: 'Confirm password', required: true }) %>
        <%- include('../partials/form-input', { label: 'Referral code (optional)', name: 'referral_code', value: formData.referral_code, placeholder: 'VK2026' }) %>
        <div class="text-xs text-slate-500">Referral codes unlock reseller benefits if you are approved later.</div>
        <label class="flex items-center gap-2 text-sm text-slate-500">
          <input type="checkbox" class="accent-red-600" required /> I agree to the terms and privacy policy.
        </label>
        <button class="btn-primary w-full" type="submit">Create account</button>
      </form>
      <p class="text-sm text-slate-500 mt-6">Already have an account? <a class="text-slate-900 font-semibold" href="/login">Login</a></p>
    </div>
  </div>
</section>

</body>
</html>
