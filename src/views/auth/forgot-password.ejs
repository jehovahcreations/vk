<% const pageTitle = "Forgot Password - VK Training Consultency"; %>
<%- include('../partials/auth-head') %>

<section class="relative overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute -top-20 -right-24 h-64 w-64 rounded-full" style="background: rgba(151, 216, 243, 0.35);"></div>
    <div class="absolute -bottom-24 -left-20 h-72 w-72 rounded-full" style="background: rgba(245, 139, 5, 0.2);"></div>
  </div>
  <div class="relative max-w-4xl mx-auto px-6 py-16">
    <div class="card p-10">
      <h2 class="text-3xl font-semibold">Reset your password</h2>
      <p class="text-slate-500 mt-2">Enter your email and we will send a reset link.</p>
      <%- include('../partials/auth-alert') %>
      <form class="mt-6 space-y-5" method="POST" action="/forgot-password">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <%- include('../partials/form-input', { label: 'Email address', name: 'email', value: formData.email, placeholder: 'you@company.com', required: true }) %>
        <button class="btn-primary w-full" type="submit">Send reset link</button>
      </form>
      <p class="text-sm text-slate-500 mt-6">Remembered your password? <a class="text-slate-900 font-semibold" href="/login">Back to login</a></p>
    </div>
  </div>
</section>

</body>
</html>
