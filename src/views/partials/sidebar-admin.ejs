<aside class="fixed inset-y-0 left-0 z-40 w-72 bg-white border-r border-slate-200 p-6 transform -translate-x-full transition duration-300 ease-in-out peer-checked:translate-x-0 lg:translate-x-0 lg:static lg:flex lg:flex-col lg:h-screen">
  <div class="flex items-center justify-between mb-10">
    <div class="flex items-center gap-3">
      <img src="/images/logo.jpeg" alt="VK Training Consultency" class="h-9 w-9 rounded-xl object-cover" />
