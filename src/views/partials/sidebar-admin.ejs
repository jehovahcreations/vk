      Video Management
    </a>
    <a class="sidebar-link" href="/admin/categories">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">C</span>
      Categories
    </a>
    <a class="sidebar-link" href="/admin/students">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">S</span>
      Students
    </a>
    <a class="sidebar-link" href="/admin/students">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">R</span>
      Resellers / Affiliates
    </a>
    <a class="sidebar-link" href="/admin/referrals">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">F</span>
      Referral Codes
    </a>
    <a class="sidebar-link" href="/admin/payments">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">O</span>
      Orders / Payments
    </a>
    <a class="sidebar-link" href="/admin/payments">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">P</span>
      Payments
    </a>
    <a class="sidebar-link" href="/admin/refunds">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">R</span>
      Refunds
    </a>
    <a class="sidebar-link" href="/admin/payment-settings">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">S</span>
      Payment Settings
    </a>
    <a class="sidebar-link" href="/admin/commissions">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">$</span>
      Commissions / Payouts
    </a>
    <a class="sidebar-link" href="/admin/affiliate-links">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">R</span>
      Reports / Analytics
    </a>
  </nav>
  <div class="mt-auto pt-10 space-y-4">
    <div class="card p-4">
      <p class="text-xs text-slate-500">Platform health</p>
      <p class="text-lg font-semibold">99.98% uptime</p>
      <div class="mt-3 h-2 rounded-full bg-slate-200">
        <div class="h-2 rounded-full" style="width: 82%; background: linear-gradient(135deg, #97D8F3, #F58B05);"></div>
      </div>
    </div>
    <form method="POST" action="/logout">
      <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>" />
      <button class="btn-outline w-full" type="submit">Logout</button>
    </form>
  </div>
</aside>
