        <p class="text-xs text-slate-500">Operations</p>
      </div>
    </div>
    <label for="admin-drawer" class="lg:hidden text-slate-500 cursor-pointer">Close</label>
  </div>
  <nav class="space-y-2 text-sm text-slate-600">
    <a class="sidebar-link sidebar-link-active" href="/admin/dashboard">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">D</span>
      Dashboard
    </a>
    <a class="sidebar-link" href="/admin/videos">
