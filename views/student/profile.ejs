<% const pageTitle = "Profile"; %>
<%- include('../partials/head') %>

<div class="min-h-screen bg-slate-50 flex">
  <input id="student-drawer" type="checkbox" class="peer hidden" />
  <%- include('../partials/sidebar-student') %>
  <label for="student-drawer" class="fixed inset-0 bg-black/30 backdrop-blur-sm opacity-0 pointer-events-none peer-checked:opacity-100 peer-checked:pointer-events-auto transition lg:hidden"></label>

  <div class="flex-1 flex flex-col min-h-screen">
    <header class="sticky top-0 z-30 bg-white/90 backdrop-blur border-b border-slate-200">
      <div class="px-6 py-5 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <label for="student-drawer" class="lg:hidden h-10 w-10 rounded-xl border border-slate-200 flex items-center justify-center cursor-pointer">Menu</label>
          <div>
            <p class="text-sm text-slate-500">Student</p>
            <h1 class="text-2xl font-semibold">Profile</h1>
          </div>
        </div>
        <button class="btn-outline" disabled>Update</button>
      </div>
    </header>

    <main class="flex-1 px-6 py-8 space-y-6">
      <section class="card p-6 max-w-3xl">
        <h2 class="text-xl font-semibold">Account details</h2>
        <div class="grid gap-4 mt-6 sm:grid-cols-2">
          <div>
            <label class="text-xs text-slate-500">Full name</label>
            <div class="mt-2 input"><%= student?.full_name || 'Student' %></div>
          </div>
          <div>
            <label class="text-xs text-slate-500">Email</label>
            <div class="mt-2 input"><%= student?.email || '-' %></div>
          </div>
          <div>
            <label class="text-xs text-slate-500">Affiliate code</label>
            <div class="mt-2 input"><%= student?.affiliate_code || '-' %></div>
          </div>
          <div>
            <label class="text-xs text-slate-500">Role</label>
            <div class="mt-2 input"><%= student?.role || 'student' %></div>
          </div>
        </div>
      </section>
    </main>
  </div>
</div>

<%- include('../partials/footer') %>
