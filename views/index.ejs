<% const pageTitle = "VK Training Consultency"; %>
<%
  const stats = homepageStats || {};
  const formatCount = (value) => Number(value || 0).toLocaleString('en-IN');
  const formatCurrency = (valueInPaise) => `INR ${(Number(valueInPaise || 0) / 100).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
%>
<%- include('partials/head') %>
<%- include('partials/navbar') %>

<section class="relative overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute -top-24 -right-24 h-72 w-72 rounded-full" style="background: rgba(151, 216, 243, 0.45);"></div>
    <div class="absolute top-24 -left-20 h-80 w-80 rounded-full" style="background: rgba(245, 139, 5, 0.18);"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-6 py-20 grid gap-12 lg:grid-cols-2 items-center">
    <div class="space-y-6">
      <span class="badge">Premium learning network</span>
      <h1 class="text-4xl md:text-5xl font-semibold leading-tight">Pay-and-watch courses built like a premium OTT experience.</h1>
      <p class="text-lg text-slate-600">Launch your next certification journey, earn affiliate rewards, and stream classroom-grade video in a platform crafted for modern professionals.</p>
      <div class="flex flex-wrap gap-4">
        <a class="btn-primary" href="/register">Start learning</a>
        <a class="btn-outline" href="/videos">Browse library</a>
      </div>
      <div class="flex items-center gap-8 pt-6">
        <div>
          <p class="text-2xl font-semibold"><%= formatCount(stats.totalCourses) %></p>
          <p class="text-sm text-slate-500">Live video courses</p>
        </div>
        <div>
          <p class="text-2xl font-semibold"><%= formatCount(stats.totalLearners) %></p>
          <p class="text-sm text-slate-500">Active learners</p>
        </div>
        <div>
          <p class="text-2xl font-semibold"><%= formatCurrency(stats.totalAffiliateEarningsInPaise) %></p>
          <p class="text-sm text-slate-500">Affiliate earnings</p>
        </div>
      </div>
    </div>
    <div class="card p-6">
      <div class="rounded-2xl bg-slate-100 h-60 flex items-center justify-center">
        <p class="text-slate-400">Hero video preview</p>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        <div class="stat-card">
          <p class="text-xs text-slate-500">7-day affiliate payout</p>
          <p class="text-xl font-semibold"><%= formatCurrency(stats.weeklyPayoutInPaise) %></p>
          <p class="text-xs text-slate-500">Credited in the last 7 days</p>
        </div>
        <div class="stat-card">
          <p class="text-xs text-slate-500">Payment success rate</p>
          <p class="text-xl font-semibold"><%= Number(stats.paymentSuccessRate || 0).toFixed(1) %>%</p>
          <p class="text-xs text-slate-500"><%= formatCount(stats.capturedPayments) %> captured payments</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="max-w-7xl mx-auto px-6 py-16">
  <div class="grid gap-8 lg:grid-cols-3">
    <div class="card p-6">
      <p class="text-xs text-slate-500">Learn</p>
      <h3 class="text-xl font-semibold mt-3">Cinematic course delivery</h3>
      <p class="text-sm text-slate-500 mt-2">Every lesson is packaged with studio-grade video, chapters, and smart notes.</p>
    </div>
    <div class="card p-6">
      <p class="text-xs text-slate-500">Earn</p>
      <h3 class="text-xl font-semibold mt-3">Affiliate-ready pathways</h3>
      <p class="text-sm text-slate-500 mt-2">Turn your certifications into revenue with personalized referral dashboards.</p>
    </div>
    <div class="card p-6">
      <p class="text-xs text-slate-500">Scale</p>
      <h3 class="text-xl font-semibold mt-3">Enterprise-grade admin tools</h3>
      <p class="text-sm text-slate-500 mt-2">Manage content, students, and payouts with an operations console.</p>
    </div>
  </div>
</section>

<section class="max-w-7xl mx-auto px-6 py-16">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h2 class="text-3xl font-semibold">Premium pricing</h2>
      <p class="text-slate-500">Plans designed for individual learners and teams.</p>
    </div>
    <span class="badge">Monthly billing</span>
  </div>
  <div class="grid gap-6 lg:grid-cols-3">
    <div class="card p-8">
      <p class="text-xs text-slate-500">Starter</p>
      <p class="text-4xl font-semibold mt-4">$29</p>
      <p class="text-sm text-slate-500 mb-6">Perfect for individual skill builders.</p>
      <ul class="space-y-2 text-sm text-slate-600">
        <li>20 premium courses</li>
        <li>Community access</li>
        <li>Basic affiliate tier</li>
      </ul>
      <button class="btn-outline w-full mt-6">Choose plan</button>
    </div>
    <div class="card p-8 border-2" style="border-color: rgba(206, 3, 3, 0.3);">
      <p class="text-xs text-slate-500">Professional</p>
      <p class="text-4xl font-semibold mt-4">$59</p>
      <p class="text-sm text-slate-500 mb-6">Unlimited learning with growth perks.</p>
      <ul class="space-y-2 text-sm text-slate-600">
        <li>Full course library</li>
        <li>Weekly live sessions</li>
        <li>Advanced affiliate tier</li>
      </ul>
      <button class="btn-primary w-full mt-6">Most popular</button>
    </div>
    <div class="card p-8">
      <p class="text-xs text-slate-500">Team</p>
      <p class="text-4xl font-semibold mt-4">$129</p>
      <p class="text-sm text-slate-500 mb-6">Launch cohorts across your company.</p>
      <ul class="space-y-2 text-sm text-slate-600">
        <li>Team analytics</li>
        <li>Dedicated support</li>
        <li>Revenue share program</li>
      </ul>
      <button class="btn-outline w-full mt-6">Talk to sales</button>
    </div>
  </div>
</section>

<section class="max-w-7xl mx-auto px-6 py-16">
  <div class="card p-10 flex flex-col lg:flex-row items-center justify-between gap-8">
    <div>
      <h2 class="text-3xl font-semibold">Ready to stream smarter?</h2>
      <p class="text-slate-500">Launch your professional learning stack today.</p>
    </div>
    <div class="flex gap-4">
      <button class="btn-primary">Start free trial</button>
      <button class="btn-outline">Request demo</button>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
