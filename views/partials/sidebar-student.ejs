<aside class="fixed inset-y-0 left-0 z-40 w-72 bg-white border-r border-slate-200 p-6 transform -translate-x-full transition duration-300 ease-in-out peer-checked:translate-x-0 lg:translate-x-0 lg:static lg:flex lg:flex-col lg:h-screen">
  <div class="flex items-center justify-between mb-10">
    <div class="flex items-center gap-3">
      <img src="/images/logo.jpeg" alt="VK Training Consultency" class="h-9 w-9 rounded-xl object-cover" />
      <div>
        <p class="font-semibold">Student Panel</p>
        <p class="text-xs text-slate-500">Elite access</p>
      </div>
    </div>
    <label for="student-drawer" class="lg:hidden text-slate-500 cursor-pointer">Close</label>
  </div>
  <nav class="space-y-2 text-sm text-slate-600">
    <a class="sidebar-link sidebar-link-active" href="/student/dashboard">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">D</span>
      Dashboard
    </a>
    <a class="sidebar-link" href="/student/purchases">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">V</span>
      My Videos
    </a>
    <a class="sidebar-link" href="/student/categories">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">C</span>
      Categories
    </a>
    <a class="sidebar-link" href="/student/purchases">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">P</span>
      Purchased Plans
    </a>
    <a class="sidebar-link" href="/student/earnings">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">$</span>
      Wallet / Earnings
    </a>
    <a class="sidebar-link" href="/student/purchases">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">M</span>
      My Purchases
    </a>
    <a class="sidebar-link" href="/student/affiliate">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">A</span>
      Affiliate / Referral
    </a>
    <a class="sidebar-link" href="/student/profile">
      <span class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center">P</span>
      Profile
    </a>
  </nav>
  <div class="mt-auto pt-10 space-y-4">
    <div class="card p-4">
      <p class="text-xs text-slate-500">Affiliate tier</p>
      <p class="text-lg font-semibold">Gold reseller</p>
      <button class="btn-soft w-full mt-4">Upgrade tier</button>
    </div>
    <form method="POST" action="/logout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <button class="btn-outline w-full" type="submit">Logout</button>
    </form>
  </div>
</aside>
