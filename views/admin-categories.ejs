<% const pageTitle = "Categories"; %>
<%- include('partials/head') %>

<div class="min-h-screen bg-slate-50 flex">
  <input id="admin-drawer" type="checkbox" class="peer hidden" />
  <%- include('partials/sidebar-admin') %>
  <label for="admin-drawer" class="fixed inset-0 bg-black/30 backdrop-blur-sm opacity-0 pointer-events-none peer-checked:opacity-100 peer-checked:pointer-events-auto transition lg:hidden"></label>

  <div class="flex-1 flex flex-col min-h-screen">
    <header class="sticky top-0 z-30 bg-white/90 backdrop-blur border-b border-slate-200">
      <div class="px-6 py-5 flex items-center justify-between">
        <div>
          <p class="text-sm text-slate-500">Admin</p>
          <h1 class="text-2xl font-semibold">Categories</h1>
        </div>
        <button class="btn-primary">Add category</button>
      </div>
    </header>

    <main class="flex-1 px-6 py-8 space-y-6">
      <section class="card p-6">
        <div class="flex items-center justify-between">
          <div>
            <h2 class="text-xl font-semibold">All categories</h2>
            <p class="text-sm text-slate-500">Organize courses and videos by theme.</p>
          </div>
          <div class="flex gap-3">
            <input class="input w-60" placeholder="Search categories" />
            <button class="btn-outline">Filter</button>
          </div>
        </div>
        <div class="mt-6 overflow-x-auto">
          <table class="table-base min-w-[640px]">
            <thead>
              <tr>
                <th>Category</th>
                <th>Videos</th>
                <th>Status</th>
                <th>Updated</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Leadership</td>
                <td>48</td>
                <td><span class="badge">Active</span></td>
                <td>Apr 10, 2026</td>
                <td><button class="btn-outline">Edit</button></td>
              </tr>
              <tr>
                <td>Product</td>
                <td>36</td>
                <td><span class="badge">Active</span></td>
                <td>Apr 8, 2026</td>
                <td><button class="btn-outline">Edit</button></td>
              </tr>
              <tr>
                <td>Marketing</td>
                <td>22</td>
                <td><span class="badge">Draft</span></td>
                <td>Apr 4, 2026</td>
                <td><button class="btn-outline">Edit</button></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>
</div>

</body>
</html>
