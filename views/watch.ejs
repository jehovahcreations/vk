<% const pageTitle = "Watch Video"; %>
<%- include('partials/head') %>
<link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />
<style>
  #watch-video-wrapper,
  #watch-embed-wrapper {
    width: 100%;
  }

  #watch-video-wrapper .plyr {
    height: 100% !important;
    max-height: none !important;
  }

  #watch-video-wrapper .plyr__video-wrapper {
    height: 100% !important;
    max-height: none !important;
    background: #000;
  }

  #watch-video-wrapper .plyr video {
    object-fit: cover;
    height: 100% !important;
    max-height: none !important;
  }

  #watch-video-player {
    height: 100% !important;
    max-height: none !important;
  }

  #watch-embed-wrapper iframe {
    width: 100% !important;
    height: 100% !important;
    display: block;
  }

  /* If a provider injects this class in the same document, force it to fill wrapper height. */
  #watch-video-wrapper .html5-video-player {
    height: 100% !important;
    max-height: none !important;
    width: 100% !important;
  }

  #watch-video-wrapper .plyr--full-ui input[type="range"] {
    color: #ce0303;
  }
</style>

<div class="min-h-screen bg-slate-50 flex">
  <input id="student-drawer" type="checkbox" class="peer hidden" />
  <%- include('partials/sidebar-student') %>
  <label for="student-drawer" class="fixed inset-0 bg-black/30 backdrop-blur-sm opacity-0 pointer-events-none peer-checked:opacity-100 peer-checked:pointer-events-auto transition lg:hidden"></label>

  <div class="flex-1 flex flex-col min-h-screen">
    <header class="sticky top-0 z-30 bg-white/90 backdrop-blur border-b border-slate-200">
      <div class="px-6 py-5 flex flex-col gap-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <label for="student-drawer" class="lg:hidden h-10 w-10 rounded-xl border border-slate-200 flex items-center justify-center cursor-pointer">Menu</label>
            <button class="btn-outline">Back</button>
            <nav class="hidden md:flex text-sm text-slate-500 gap-2">
              <span>Dashboard</span>
              <span>/</span>
              <span>My Videos</span>
              <span>/</span>
              <span>Leadership Intensive</span>
              <span>/</span>
              <span class="text-slate-900">Lesson 04</span>
            </nav>
          </div>
          <button class="btn-primary hidden sm:inline-flex">Explore Videos</button>
        </div>
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
          <div>
            <h1 class="text-2xl font-semibold"><%= video?.title || 'Video session' %></h1>
            <p class="text-sm text-slate-500">
              <%= video?.description || 'Enjoy your premium lesson with full access.' %>
              · <span class="text-emerald-600">Active Access</span>
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            <span class="badge">Premium</span>
            <span class="badge">Unlocked</span>
            <span class="badge">4.9 rating</span>
          </div>
        </div>
      </div>
    </header>

    <main class="flex-1 px-6 py-8">
      <section class="max-w-5xl">
        <div class="card p-4">
            <div class="rounded-2xl bg-slate-900 overflow-hidden">
              <% if (streamUrl) { %>
                <div id="watch-video-wrapper" class="bg-black" style="height: 420px; max-height: 75vh; min-height: 220px;">
                  <video
                    id="watch-video-player"
                    class="w-full h-full object-cover"
                    controls
                    preload="metadata"
                    playsinline
                    controlsList="nodownload"
                  >
                    <source src="<%= streamUrl %>" />
                    Your browser does not support the video tag.
                  </video>
                </div>
                <% if (embedUrl) { %>
                  <div id="watch-embed-wrapper" class="hidden bg-black" style="aspect-ratio: 16 / 9; max-height: 75vh; min-height: 220px;">
                    <iframe
                      class="w-full h-full"
                      src="<%= embedUrl %>"
                      allow="autoplay; encrypted-media"
                      allowfullscreen
                    ></iframe>
                  </div>
                <% } %>
              <% } else if (embedUrl) { %>
                <div class="aspect-video">
                  <iframe
                    class="w-full h-full"
                    src="<%= embedUrl %>"
                    allow="autoplay; encrypted-media"
                    allowfullscreen
                  ></iframe>
                </div>
              <% } else { %>
                <div class="h-[320px] md:h-[420px] flex items-center justify-center text-slate-300">
                  <div class="text-center space-y-2">
                    <p class="text-sm">Video is not available for in-page playback yet.</p>
                  </div>
                </div>
              <% } %>
            </div>
            <% if (isDriveVideo) { %>
              <div class="mt-3 flex flex-wrap items-center justify-between gap-2">
                <p class="text-xs text-slate-500">Enhanced player mode is active. If Drive blocks direct stream, it will switch to embedded playback in-page.</p>
                <button
                  id="watch-size-toggle"
                  type="button"
                  class="btn-outline text-xs px-3 py-1"
                  aria-pressed="false"
                >
                  Increase size
                </button>
              </div>
            <% } else { %>
              <div class="mt-3 flex justify-end">
                <button
                  id="watch-size-toggle"
                  type="button"
                  class="btn-outline text-xs px-3 py-1"
                  aria-pressed="false"
                >
                  Increase size
                </button>
              </div>
            <% } %>
            <div class="mt-3 flex flex-wrap items-center justify-between gap-2 text-xs text-slate-500">
              <p id="watch-video-metrics">Loading video details...</p>
              <p id="watch-video-time">0:00 / 0:00</p>
            </div>
            <div class="mt-4 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
              <div>
                <h2 class="text-xl font-semibold"><%= video?.title || 'Lesson' %></h2>
                <p class="text-sm text-slate-500"><%= video?.description || 'Video overview details appear here.' %></p>
              </div>
              <div class="flex items-center gap-3 text-sm text-slate-500">
                <span id="watch-progress-label">Progress 0%</span>
                <div class="h-2 w-32 rounded-full bg-slate-200">
                  <div id="watch-progress-bar" class="h-2 rounded-full" style="width: 0%; background: linear-gradient(135deg, #CE0303, #F58B05);"></div>
                </div>
              </div>
            </div>
          </div>
      </section>
    </main>
  </div>
</div>

<script src="https://cdn.plyr.io/3.7.8/plyr.polyfilled.js"></script>
<script>
  (function () {
    const video = document.getElementById('watch-video-player');
    const videoWrapper = document.getElementById('watch-video-wrapper');
    const embedWrapper = document.getElementById('watch-embed-wrapper');
    const metricsEl = document.getElementById('watch-video-metrics');
    const timeEl = document.getElementById('watch-video-time');
    const progressLabel = document.getElementById('watch-progress-label');
    const progressBar = document.getElementById('watch-progress-bar');
    const sizeToggleBtn = document.getElementById('watch-size-toggle');
    const driveId = '<%= driveId || "" %>';
    const isDriveVideo = <%= isDriveVideo ? 'true' : 'false' %>;
    const driveSources = <%- JSON.stringify(driveStreamCandidates || []) %>;
    let currentIntrinsicWidth = 16;
    let currentIntrinsicHeight = 9;
    let activeDriveSourceIndex = 0;
    let startupFallbackTimer = null;
    let hasSwitchedToEmbed = false;
    let sizeScale = 1.25;

    function hasReliableDimensions(width, height) {
      if (!Number.isFinite(width) || !Number.isFinite(height)) return false;
      if (width < 160 || height < 90) return false;
      const ratio = width / height;
      return ratio > 0.3 && ratio < 3.5;
    }

    function applyDefaultPlayerSize(wrapper) {
      if (!wrapper) return;
      setWrapperRatio(wrapper, 16, 9);
    }

    function setWrapperRatio(wrapper, width, height) {
      if (!wrapper || !width || !height) return;
      currentIntrinsicWidth = width;
      currentIntrinsicHeight = height;

      const availableWidth = Math.max(1, Math.round(wrapper.clientWidth || wrapper.parentElement?.clientWidth || 0));
      const maxHeight = Math.round(window.innerHeight * 0.9);
      const minHeight = 300;
      const computedHeight = Math.round(((availableWidth * height) / width) * sizeScale);
      const clampedHeight = Math.max(minHeight, Math.min(maxHeight, computedHeight));

      wrapper.style.height = clampedHeight + 'px';
      wrapper.style.maxHeight = maxHeight + 'px';
      wrapper.style.minHeight = minHeight + 'px';
    }

    function formatTime(totalSeconds) {
      if (!Number.isFinite(totalSeconds) || totalSeconds < 0) return '0:00';
      const secs = Math.floor(totalSeconds);
      const hours = Math.floor(secs / 3600);
      const minutes = Math.floor((secs % 3600) / 60);
      const seconds = secs % 60;

      if (hours > 0) {
        return hours + ':' + String(minutes).padStart(2, '0') + ':' + String(seconds).padStart(2, '0');
      }

      return minutes + ':' + String(seconds).padStart(2, '0');
    }

    function updateProgress() {
      if (!video || !progressLabel || !progressBar || !timeEl) return;
      const duration = Number.isFinite(video.duration) ? video.duration : 0;
      const current = Number.isFinite(video.currentTime) ? video.currentTime : 0;
      const percent = duration > 0 ? Math.min(100, (current / duration) * 100) : 0;

      progressLabel.textContent = 'Progress ' + Math.round(percent) + '%';
      progressBar.style.width = percent.toFixed(2) + '%';
      timeEl.textContent = formatTime(current) + ' / ' + formatTime(duration);
    }

    function updateMetrics() {
      if (!video || !metricsEl) return;

      const intrinsicW = video.videoWidth || 0;
      const intrinsicH = video.videoHeight || 0;
      const playerH = Math.round(video.getBoundingClientRect().height || 0);

      if (hasReliableDimensions(intrinsicW, intrinsicH)) {
        setWrapperRatio(videoWrapper, intrinsicW, intrinsicH);
        metricsEl.textContent = 'Resolution ' + intrinsicW + 'x' + intrinsicH + ' · Actual height ' + intrinsicH + 'px · Player height ' + playerH + 'px';
      } else {
        applyDefaultPlayerSize(videoWrapper);
        metricsEl.textContent = 'Using standard player size (16:9). Drive stream metadata is not reliable yet.';
      }
    }

    function updateDriveEmbedRatioFromThumbnail() {
      if (!embedWrapper || !driveId) return;

      // Keep fallback embed at a stable 16:9 frame; Drive preview pages often include
      // extra document space if iframe height is stretched based on thumbnail ratio.
      setWrapperRatio(embedWrapper, 16, 9);
    }

    function updateSizeToggleUi() {
      if (!sizeToggleBtn) return;
      const enlarged = sizeScale > 1;
      sizeToggleBtn.textContent = enlarged ? 'Normal size' : 'Increase size';
      sizeToggleBtn.setAttribute('aria-pressed', enlarged ? 'true' : 'false');
    }

    function togglePlayerSize() {
      sizeScale = sizeScale > 1 ? 1 : 1.25;
      updateSizeToggleUi();
      updateWrapperSizeOnResize();
      updateMetrics();
    }

    function updateWrapperSizeOnResize() {
      if (video && videoWrapper && hasReliableDimensions(video.videoWidth, video.videoHeight)) {
        setWrapperRatio(videoWrapper, video.videoWidth, video.videoHeight);
        return;
      }

      if (videoWrapper && !hasSwitchedToEmbed) {
        applyDefaultPlayerSize(videoWrapper);
      }

      if (embedWrapper) updateDriveEmbedRatioFromThumbnail();
    }

    if (!video) {
      if (metricsEl && embedWrapper) {
        metricsEl.textContent = 'Embedded mode active. Live resolution/progress telemetry is limited by browser security policies.';
      }
      if (timeEl && embedWrapper) {
        timeEl.textContent = 'Live progress unavailable in embedded mode.';
      }
      if (progressLabel && embedWrapper) {
        progressLabel.textContent = 'Progress unavailable';
      }
      if (progressBar && embedWrapper) {
        progressBar.style.width = '0%';
      }
      updateDriveEmbedRatioFromThumbnail();
      return;
    }

    if (!videoWrapper || !embedWrapper) return;

    function clearStartupFallbackTimer() {
      if (startupFallbackTimer) {
        clearTimeout(startupFallbackTimer);
        startupFallbackTimer = null;
      }
    }

    function switchToEmbed(message) {
      if (hasSwitchedToEmbed) return;
      hasSwitchedToEmbed = true;
      clearStartupFallbackTimer();

      if (enhancedPlayer && typeof enhancedPlayer.destroy === 'function') {
        enhancedPlayer.destroy();
        enhancedPlayer = null;
      }

      videoWrapper.classList.add('hidden');
      embedWrapper.classList.remove('hidden');

      if (metricsEl) {
        metricsEl.textContent = message || 'Direct stream blocked. Switched to embedded mode. If this still fails, set Google Drive sharing to Anyone with the link (Viewer).';
      }
      if (timeEl) {
        timeEl.textContent = 'Live progress is unavailable in embedded fallback mode.';
      }
      if (progressLabel) {
        progressLabel.textContent = 'Progress unavailable';
      }
      if (progressBar) {
        progressBar.style.width = '0%';
      }
    }

    function armStartupFallbackTimer() {
      if (!isDriveVideo || hasSwitchedToEmbed) return;
      clearStartupFallbackTimer();

      startupFallbackTimer = setTimeout(function () {
        const noDuration = !Number.isFinite(video.duration) || video.duration <= 0;
        const noData = video.readyState < 2;
        const atStart = (video.currentTime || 0) === 0;

        if (noDuration && noData && atStart) {
          switchToEmbed('Drive stream is taking too long to start. Switched to embedded mode.');
        }
      }, 4500);
    }

    let enhancedPlayer = null;
    if (typeof window.Plyr === 'function') {
      enhancedPlayer = new window.Plyr(video, {
        controls: [
          'play-large',
          'play',
          'progress',
          'current-time',
          'duration',
          'mute',
          'volume',
          'settings',
          'pip',
          'airplay',
          'fullscreen'
        ],
        settings: ['speed'],
        speed: { selected: 1, options: [0.5, 0.75, 1, 1.25, 1.5, 2] },
        tooltips: { controls: true, seek: true },
        keyboard: { focused: true, global: true }
      });
    }

    // Keep playback inside the website by switching to iframe when direct stream is blocked.
    video.addEventListener('error', function () {
      clearStartupFallbackTimer();

      if (driveSources.length > activeDriveSourceIndex + 1) {
        activeDriveSourceIndex += 1;
        const nextSrc = driveSources[activeDriveSourceIndex];
        if (nextSrc) {
          if (metricsEl) {
            metricsEl.textContent = 'Retrying video stream source...';
          }
          video.src = nextSrc;
          video.load();
          armStartupFallbackTimer();
          return;
        }
      }

      switchToEmbed('Direct stream blocked. Switched to embedded mode. If this still fails, set Google Drive sharing to Anyone with the link (Viewer).');
    });

    video.addEventListener('loadedmetadata', function () {
      clearStartupFallbackTimer();
      updateMetrics();
      updateProgress();
    });

    video.addEventListener('loadeddata', clearStartupFallbackTimer);
    video.addEventListener('canplay', clearStartupFallbackTimer);
    video.addEventListener('playing', clearStartupFallbackTimer);
    video.addEventListener('stalled', function () {
      if (isDriveVideo) armStartupFallbackTimer();
    });
    video.addEventListener('abort', function () {
      if (isDriveVideo) armStartupFallbackTimer();
    });
    video.addEventListener('emptied', function () {
      if (isDriveVideo) armStartupFallbackTimer();
    });

    video.addEventListener('timeupdate', updateProgress);
    window.addEventListener('resize', function () {
      updateMetrics();
      updateWrapperSizeOnResize();
    });
    if (sizeToggleBtn) {
      sizeToggleBtn.addEventListener('click', togglePlayerSize);
    }
    updateSizeToggleUi();
    applyDefaultPlayerSize(videoWrapper);
    updateDriveEmbedRatioFromThumbnail();
    armStartupFallbackTimer();
  })();
</script>

<%- include('partials/footer') %>
