<% const pageTitle = "Courses"; %>
<%- include('partials/head') %>
<%- include('partials/navbar') %>

<section class="max-w-7xl mx-auto px-6 py-12">
  <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6">
    <div>
      <h1 class="text-3xl font-semibold">Streaming course library</h1>
      <p class="text-slate-500">Browse premium tracks and pay per watch.</p>
    </div>
    <form class="flex flex-wrap gap-3" method="GET" action="/videos">
      <input class="input w-64" name="search" value="<%= filters?.search || '' %>" placeholder="Search courses" />
      <button class="btn-primary" type="submit">Filter</button>
    </form>
  </div>

  <div class="flex flex-wrap gap-3 mt-8">
    <span class="badge">Trending</span>
    <span class="badge">New drops</span>
    <span class="badge">Certification</span>
    <span class="badge">Beginner friendly</span>
  </div>

  <div class="grid gap-6 mt-8 sm:grid-cols-2 lg:grid-cols-3">
    <% if (!videos || !videos.length) { %>
      <div class="text-slate-500">No videos found.</div>
    <% } %>
    <% videos.forEach((video) => { %>
      <div class="video-card">
        <div class="h-44 bg-slate-100 flex items-center justify-center">
          <% if (video.thumbnail_url) { %>
            <img src="<%= video.thumbnail_url %>" alt="<%= video.title %>" class="h-full w-full object-cover" />
          <% } else { %>
            <p class="text-slate-400">Course thumbnail</p>
          <% } %>
        </div>
        <div class="p-5 space-y-3">
          <div class="flex items-center justify-between">
            <p class="text-sm font-semibold"><%= video.title %></p>
            <span class="badge"><%= (Number(video.price_in_paise || 0) / 100).toLocaleString('en-IN', { style: 'currency', currency: video.currency || 'INR' }) %></span>
          </div>
          <p class="text-xs text-slate-500"><%= video.description || 'Premium lesson access' %></p>
          <% const studentLoggedIn = isAuthenticated && isStudent; %>
          <% const canWatch = studentLoggedIn && video.hasAccess; %>
          <% const actionLink = !isAuthenticated
            ? '/login'
            : canWatch
              ? `/videos/${video.slug}`
              : studentLoggedIn
                ? `/student/products/${video.slug}/checkout`
                : '/access-denied'; %>
          <% const actionLabel = !isAuthenticated
            ? 'Login to unlock'
            : canWatch
              ? 'Watch now'
              : studentLoggedIn
                ? 'Purchase to watch'
                : 'Student access only'; %>
          <a class="btn-primary w-full" href="<%= actionLink %>"><%= actionLabel %></a>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<%- include('partials/footer') %>
