<%- include('../../partials/head') %>

<div class="min-h-screen bg-slate-50 flex">
  <input id="admin-drawer" type="checkbox" class="peer hidden" />
  <%- include('../../partials/sidebar-admin') %>
  <label for="admin-drawer" class="fixed inset-0 bg-black/30 backdrop-blur-sm opacity-0 pointer-events-none peer-checked:opacity-100 peer-checked:pointer-events-auto transition lg:hidden"></label>

  <div class="flex-1 flex flex-col min-h-screen">
    <header class="sticky top-0 z-30 bg-white/90 backdrop-blur border-b border-slate-200">
      <div class="px-6 py-5 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <label for="admin-drawer" class="lg:hidden h-10 w-10 rounded-xl border border-slate-200 flex items-center justify-center cursor-pointer">Menu</label>
          <div>
            <p class="text-sm text-slate-500">Admin</p>
            <h1 class="text-2xl font-semibold"><%= pageTitle %></h1>
          </div>
        </div>
        <a class="btn-outline" href="/admin/students">Back to list</a>
      </div>
    </header>

    <main class="flex-1 px-6 py-10">
      <% if (flashMessages && flashMessages.length) { %>
        <div class="space-y-2 mb-6">
          <% flashMessages.forEach((item) => { %>
            <div class="card p-4">
              <p class="text-sm <%= item.type === 'error' ? 'text-red-600' : 'text-emerald-600' %>"><%= item.message %></p>
            </div>
          <% }) %>
        </div>
      <% } %>

      <div class="card p-8 max-w-3xl">
        <form class="space-y-5" method="POST" action="<%= action %>">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div>
            <label class="text-sm font-medium">Full name</label>
            <input class="input mt-2" name="full_name" value="<%= student.full_name || '' %>" required />
          </div>
          <div>
            <label class="text-sm font-medium">Email</label>
            <input class="input mt-2" name="email" type="email" value="<%= student.email || '' %>" required />
          </div>
          <div>
            <label class="text-sm font-medium">Phone</label>
            <input class="input mt-2" name="phone" value="<%= student.phone || '' %>" required />
          </div>
          <div>
            <label class="text-sm font-medium">Password</label>
            <input class="input mt-2" name="password" type="password" placeholder="<%= student.id ? 'Leave blank to keep current' : 'Create a password' %>" <%= student.id ? '' : 'required' %> />
            <p class="text-xs text-slate-500 mt-2">Minimum 8 characters.</p>
          </div>
          <div>
            <label class="text-sm font-medium">Referral commission (%)</label>
            <input
              class="input mt-2"
              name="commission_percent"
              type="number"
              min="0"
              max="100"
              step="0.01"
              value="<%= typeof student.commission_percent !== 'undefined' ? student.commission_percent : 0 %>"
              required
            />
            <p class="text-xs text-slate-500 mt-2">Applied when users referred by this affiliate purchase a video.</p>
          </div>
          <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-6">
            <label class="inline-flex items-center gap-2 text-sm">
              <input type="checkbox" name="is_reseller" class="rounded" <%= student.is_reseller ? 'checked' : '' %> />
              Reseller access
            </label>
            <label class="inline-flex items-center gap-2 text-sm">
              <input type="checkbox" name="is_active" class="rounded" <%= student.is_active ? 'checked' : '' %> />
              Active account
            </label>
          </div>
          <button class="btn-primary" type="submit"><%= submitLabel %></button>
        </form>
      </div>
    </main>
  </div>
</div>

</body>
</html>
