{
  "name": "vidstream-ui",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "build:css": "tailwindcss -i ./src/styles/tailwind.css -o ./public/styles.css --minify",
    "watch:css": "tailwindcss -i ./src/styles/tailwind.css -o ./public/styles.css --watch",
    "seed:admin": "node scripts/seed-admin.js",
    "migrate:commission": "node scripts/migrate-add-commission-percent.js",
    "migrate:commission-payouts": "node scripts/migrate-commission-payouts.js",
    "seed:products": "psql \"$DATABASE_URL\" -f db/seed-products.sql"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "connect-pg-simple": "^9.0.1",
    "cookie-parser": "^1.4.7",
    "crypto": "^1.0.1",
    "csurf": "^1.11.0",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.10",
    "express": "^4.22.1",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.20.0",
    "razorpay": "^2.9.4"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.18",
    "nodemon": "^3.1.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.4"
  }
}
